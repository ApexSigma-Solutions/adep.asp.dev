{
  "name": "ApexSigma Ecosystem - Complete Development Environment",
  "dockerComposeFile": "../docker-compose.unified.yml",
  "service": "workspace",
  "workspaceFolder": "/workspace",

  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    "ghcr.io/devcontainers/features/powershell:1": {},
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": "true",
      "configureZshAsDefaultShell": "false",
      "installOhMyZsh": "false",
      "upgradePackages": "true",
      "username": "vscode",
      "userUid": "automatic",
      "userGid": "automatic"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "ms-python.mypy-type-checker",
        "ms-python.black-formatter",
        "ms-python.isort",
        "ms-azuretools.vscode-docker",
        "github.vscode-github-actions",
        "redhat.vscode-yaml",
        "ms-vscode.makefile-tools",
        "ms-vscode-remote.remote-containers",
        "ms-vscode.vscode-json",
        "esbenp.prettier-vscode",
        "tamasfe.even-better-toml",
        "ms-vscode.vscode-typescript-next",
        "bradlc.vscode-tailwindcss",
        "ms-vscode.test-adapter-converter",
        "hbenl.vscode-test-explorer",
        "ms-vscode.vscode-jupyter-powertoys",
        "ms-vscode.vscode-sql",
        "cweijan.vscode-redis-client",
        "ms-vscode.vscode-postgresql",
        "ms-vscode.vscode-mongo",
        "humao.rest-client",
        "ms-vscode.vscode-debug-visualizer",
        "ms-vscode.hexeditor",
        "ms-vscode.vscode-git-graph",
        "gruntfuggly.todo-tree",
        "christian-kohler.path-intellisense",
        "ms-vscode.vscode-markdown-notebook",
        "redhat.vscode-xml",
        "ms-vscode.vscode-apimanagement"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.linting.enabled": true,
        "python.linting.ruffEnabled": true,
        "python.linting.mypyEnabled": true,
        "python.formatting.provider": "black",
        "python.sortImports.args": ["--profile", "black"],
        "python.testing.pytestEnabled": true,
        "python.testing.unittestEnabled": false,
        "python.testing.pytestArgs": [
          "--junit-xml=reports/junit.xml",
          "--cov",
          "--cov-report=html"
        ],
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.organizeImports": "explicit",
          "source.fixAll.ruff": "explicit"
        },
        "docker.compose.project": "docker-compose.unified.yml",
        "files.exclude": {
          "**/__pycache__": true,
          "**/.pytest_cache": true,
          "**/*.pyc": true,
          "**/.mypy_cache": true,
          "**/node_modules": true,
          "**/.ruff_cache": true,
          "**/htmlcov": true,
          "**/reports": true
        },
        "terminal.integrated.shell.linux": "/bin/bash",
        "git.autofetch": true,
        "git.enableSmartCommit": true,
        "git.confirmSync": false,
        "workbench.editor.enablePreview": false,
        "explorer.confirmDelete": false,
        "editor.minimap.enabled": false,
        "editor.renderWhitespace": "boundary",
        "editor.rulers": [88, 120],
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true,
        "search.exclude": {
          "**/node_modules": true,
          "**/.pytest_cache": true,
          "**/__pycache__": true,
          "**/.mypy_cache": true,
          "**/.ruff_cache": true,
          "**/htmlcov": true,
          "**/reports": true
        },
        "emmet.includeLanguages": {
          "jinja-html": "html"
        },
        "redhat.telemetry.enabled": false,
        "github.copilot.enable": {
          "*": true
        }
      }
    }
  },

  "forwardPorts": [
    8001, // devenviro.as API
    8002, // devenviro.as Gemini listener
    8090, // memos.as
    8000, // InGest-LLM.as
    8003, // tools.as
    5432, // PostgreSQL
    6379, // Redis
    5672, // RabbitMQ AMQP
    15672, // RabbitMQ Management
    6333, // Qdrant
    7474, // Neo4j HTTP
    7687, // Neo4j Bolt
    9090, // Prometheus
    3000, // Grafana
    16686, // Jaeger
    8200, // Vault
    8889, // Dagster
    3001, // Langfuse
    9123, // ClickHouse HTTP
    3080 // Dagster webserver
  ],

  "portsAttributes": {
    "8001": { "label": "DevEnviro API", "onAutoForward": "notify" },
    "8002": { "label": "Gemini Listener", "onAutoForward": "silent" },
    "8090": { "label": "memOS API", "onAutoForward": "notify" },
    "8000": { "label": "InGest-LLM API", "onAutoForward": "notify" },
    "8003": { "label": "Tools API", "onAutoForward": "notify" },
    "5432": { "label": "PostgreSQL", "onAutoForward": "silent" },
    "6379": { "label": "Redis", "onAutoForward": "silent" },
    "5672": { "label": "RabbitMQ AMQP", "onAutoForward": "silent" },
    "15672": { "label": "RabbitMQ Management", "onAutoForward": "notify" },
    "6333": { "label": "Qdrant", "onAutoForward": "silent" },
    "7474": { "label": "Neo4j Browser", "onAutoForward": "notify" },
    "7687": { "label": "Neo4j Bolt", "onAutoForward": "silent" },
    "9090": { "label": "Prometheus", "onAutoForward": "notify" },
    "3000": { "label": "Grafana", "onAutoForward": "notify" },
    "16686": { "label": "Jaeger", "onAutoForward": "notify" },
    "8200": { "label": "Vault", "onAutoForward": "silent" },
    "8889": { "label": "Dagster", "onAutoForward": "notify" },
    "3001": { "label": "Langfuse", "onAutoForward": "notify" },
    "9123": { "label": "ClickHouse", "onAutoForward": "silent" },
    "3080": { "label": "Dagster Web", "onAutoForward": "notify" }
  },

  "postCreateCommand": "bash .devcontainer/setup.sh",

  "remoteUser": "vscode",

  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],

  "containerEnv": {
    "PYTHONUNBUFFERED": "1",
    "POETRY_VIRTUALENVS_IN_PROJECT": "true",
    "POETRY_NO_INTERACTION": "1",
    "PYTHONDONTWRITEBYTECODE": "1",
    "PYTHONPATH": "/workspace",
    "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}",
    "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}",
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "GEMINI_API_KEY": "${localEnv:GEMINI_API_KEY}",
    "LANGFUSE_HOST": "https://cloud.langfuse.com",
    "LANGFUSE_PUBLIC_KEY": "${localEnv:LANGFUSE_PUBLIC_KEY}",
    "LANGFUSE_SECRET_KEY": "${localEnv:LANGFUSE_SECRET_KEY}",
    "POSTGRES_HOST": "apexsigma_postgres",
    "REDIS_HOST": "apexsigma_redis",
    "RABBITMQ_HOST": "apexsigma_rabbitmq",
    "QDRANT_HOST": "apexsigma_qdrant",
    "NEO4J_HOST": "apexsigma_neo4j",
    "INGEST_LLM_HOST": "172.26.0.12",
    "MEMOS_HOST": "172.26.0.13",
    "CLICKHOUSE_HOST": "apexsigma_clickhouse",
    "VAULT_HOST": "apexsigma_vault"
  }
}
