# === ApexSigma Canonical Environment Configuration ===
# This is the authoritative environment configuration for the entire ecosystem
# Copy to .env and fill in your specific values

# === Database Configuration ===
POSTGRES_HOST=apexsigma_postgres
POSTGRES_PORT=5432
POSTGRES_DB=apexsigma_db
POSTGRES_USER=apexsigma_user
POSTGRES_PASSWORD=CHANGE_ME

# === Redis Configuration ===
REDIS_HOST=apexsigma_redis
REDIS_PORT=6379

# === Qdrant Vector Database ===
QDRANT_HOST=apexsigma_qdrant
QDRANT_PORT=6333

# === Neo4j Graph Database ===
NEO4J_HOST=apexsigma_neo4j
NEO4J_PORT=7687
NEO4J_AUTH=neo4j/YOUR_NEO4J_PASSWORD

# === RabbitMQ Message Queue ===
RABBITMQ_HOST=apexsigma_rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=apexsigma_user
RABBITMQ_PASSWORD=CHANGE_ME

# === Service Configuration ===
# Internal Docker network ports (no host mapping)
DEVENVIRO_API_PORT=8000
MEMOS_API_PORT=8090
INGEST_LLM_API_PORT=8000
TOOLS_API_PORT=8000
DAGSTER_WEBSERVER_PORT=8080

# === External Services ===
# Langfuse AI Tracing & Observability (OVS-WO-002 Compliance)
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=pk-lf-CHANGE_ME
LANGFUSE_SECRET_KEY=sk-lf-YOUR_SECRET_KEY_HERE
LANGFUSE_TRACING_URL=http://localhost:3001
LANGFUSE_SALT=CHANGE_ME_SECURE_SALT_FOR_ENCRYPTION

# Serper API for web search
SERPER_API_KEY=CHANGE_ME

# Trunk API token for CI/CD
TRUNK_API_TOKEN=CHANGE_ME

# === Environment Settings ===
ENVIRONMENT=development
LOG_LEVEL=INFO

# === Test Configuration ===
TEST_DATABASE_URL=postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME

# === Dagster Configuration ===
DAGSTER_POSTGRES_HOST=postgres
DAGSTER_POSTGRES_PORT=5432
DAGSTER_POSTGRES_USER=apexsigma_user
DAGSTER_POSTGRES_PASSWORD=CHANGE_ME
DAGSTER_POSTGRES_DB=apexsigma_db

# === ClickHouse Configuration ===
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=clickhouse_user
CLICKHOUSE_PASSWORD=CHANGE_ME_SECURELY
CLICKHOUSE_DB=apexsigma_observability
CLICKHOUSE_NATIVE_PORT=9000

# === Docker Compose Network ===
COMPOSE_PROJECT_NAME=apexsigma
