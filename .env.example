# Environment Configuration
NODE_ENV=development

# Database Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=adep
POSTGRES_USER=adep_user
POSTGRES_PASSWORD=adep_password

# Redis Configuration
REDIS_URL=redis://redis:6379

# Service Ports
API_GATEWAY_PORT=8080
PIPELINE_ORCHESTRATOR_PORT=8081
CODE_ANALYZER_PORT=8082
DEPLOYMENT_MANAGER_PORT=8083
AGENT_COORDINATOR_PORT=8084

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Security
JWT_SECRET=your-jwt-secret-here
API_RATE_LIMIT=100

# External Services
GITHUB_TOKEN=your-github-token
DOCKER_REGISTRY=your-registry-url